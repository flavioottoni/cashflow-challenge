{
  "name": "cashflow-challenge",
  "version": "1.0.0",
  "private": true,
  "description": "Desafio Arquiteto de Soluções - Controle de Fluxo de Caixa",
  "workspaces": [
    "apps/*",
    "libs/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "start:entries": "npm run start:dev -w entries-service",
    "start:consolidated": "npm run start:dev -w consolidated-service",
    "start:gateway": "npm run start:dev -w api-gateway",
    "test": "npm run test --workspaces --if-present && jest --config jest.config.js",
    "test:e2e": "npm run test:e2e -w entries-service",
    "load-test": "k6 run tests/load/consolidated-load.js",
    "lint": "eslint \"{apps,libs}/**/*.ts\" --fix"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.2",
    "@typescript-eslint/eslint-plugin": "^8.18.1",
    "@typescript-eslint/parser": "^8.18.1",
    "eslint": "^9.17.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
